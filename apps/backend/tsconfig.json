{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@/generated/*": ["generated/*"],
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts", "generated/**/*.ts", "prisma.config.ts"],
  "exclude": ["node_modules"]
}
