{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowArbitraryExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["vite/client", "vitest/globals", "bun-types", "node"],
    "baseUrl": ".",
    "paths": {
      "@/generated/*": ["./generated/*"],
      "@/*": ["./src/*", "./server/*", "./*"]
    }
  },
  "include": ["src", "api", "server", "app", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
